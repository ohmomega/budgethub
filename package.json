{
  "name": "budgethub",
  "productName": "BudgetHub",
  "version": "1.0.2",
  "description": "BudgetHub — ระบบบริหารงบประมาณรายจ่ายแผนก (offline desktop app)",
  "author": "ohmomega",
  "license": "MIT",
  "homepage": "https://github.com/ohmomega/budgethub",
  "repository": {
    "type": "git",
    "url": "https://github.com/ohmomega/budgethub.git"
  },
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "seed": "node backend/seed.js",
    "seed:demo": "node backend/seed.js --demo",
    "server": "node backend/app.js",
    "build:frontend": "npm --prefix frontend install && npm --prefix frontend run build",
    "dist": "npm run build:frontend && electron-builder --win nsis"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "electron": "^31.7.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.budgethub.app",
    "productName": "BudgetHub",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "files": [
      "electron/**/*",
      "backend/**/*",
      "!backend/node_modules/**/*",
      "!backend/.env",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "frontend/dist",
        "to": "dist"
      },
      {
        "from": "Example",
        "to": "Example"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": "x64"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BudgetHub",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "directories": {
      "output": "dist_electron"
    }
  }
}
